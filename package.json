{
  "name": "speed_reader_web_app",
  "version": "1.0.0",
  "description": "Standalone web application for speed reading using RSVP (Rapid Serial Visual Presentation) technique.",
  "scripts": {
    "build:defuddle": "esbuild node_modules/defuddle/dist/index.js --bundle --format=iife --global-name=Defuddle --outfile=public/src/Defuddle.js --minify",
    "postinstall": "npm run build:defuddle",
    "dev": "python3 -m http.server 8000",
    "serve": "npx serve ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "defuddle": "^0.17.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
